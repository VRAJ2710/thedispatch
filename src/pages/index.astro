---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
).slice(0, 3);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<h1>The Dispatch</h1>
				<p class="tagline">
					Your daily briefing on tech, software, and the web — clear, concise, and to the point.
				</p>
				<a href="/blog" class="cta">Read the latest →</a>
			</section>

			<section class="recent-posts">
				<h2>Latest Posts</h2>
				<ul>
					{posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								{post.data.heroImage && (
									<img src={post.data.heroImage} alt={post.data.title} />
								)}
								<div class="post-info">
									<h3>{post.data.title}</h3>
									<p class="date"><FormattedDate date={post.data.pubDate} /></p>
									<p class="description">{post.data.description}</p>
								</div>
							</a>
						</li>
					))}
				</ul>
				<a href="/blog" class="view-all">View all posts →</a>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 800px;
		margin: 0 auto;
		padding: 2rem 1rem;
	}

	.hero {
		text-align: center;
		padding: 4rem 0 3rem;
		border-bottom: 1px solid rgb(var(--gray-light));
		margin-bottom: 3rem;
	}

	.hero h1 {
		font-size: 3.5rem;
		margin: 0 0 1rem;
	}

	.tagline {
		font-size: 1.2rem;
		color: rgb(var(--gray));
		max-width: 500px;
		margin: 0 auto 2rem;
		line-height: 1.6;
	}

	.cta {
		display: inline-block;
		background: var(--accent);
		color: white;
		padding: 0.75rem 1.5rem;
		border-radius: 4px;
		text-decoration: none;
		font-weight: 600;
		transition: opacity 0.2s;
	}

	.cta:hover {
		opacity: 0.85;
	}

	.recent-posts h2 {
		font-size: 1.5rem;
		margin-bottom: 1.5rem;
	}

	.recent-posts ul {
		list-style: none;
		padding: 0;
		margin: 0 0 2rem;
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.recent-posts li a {
		display: flex;
		gap: 1.5rem;
		text-decoration: none;
		color: inherit;
		align-items: flex-start;
	}

	.recent-posts li a:hover h3 {
		color: var(--accent);
	}

	.recent-posts img {
		width: 160px;
		height: 100px;
		object-fit: cover;
		border-radius: 4px;
		flex-shrink: 0;
	}

	.post-info h3 {
		margin: 0 0 0.25rem;
		font-size: 1.1rem;
		transition: color 0.2s;
	}

	.date {
		font-size: 0.85rem;
		color: rgb(var(--gray));
		margin: 0 0 0.5rem;
	}

	.description {
		font-size: 0.95rem;
		color: rgb(var(--gray-dark));
		margin: 0;
		line-height: 1.5;
	}

	.view-all {
		color: var(--accent);
		text-decoration: none;
		font-weight: 600;
	}

	.view-all:hover {
		text-decoration: underline;
	}

	@media (max-width: 600px) {
		.hero h1 {
			font-size: 2.5rem;
		}

		.recent-posts li a {
			flex-direction: column;
		}

		.recent-posts img {
			width: 100%;
			height: 180px;
		}
	}
</style>
